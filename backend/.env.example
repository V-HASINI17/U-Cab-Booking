# ─── UCAB Backend — Environment Variables Template ───────────────────────────
# Copy this file to `.env` and fill in your values. NEVER commit the real .env.

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/Ucab

# JWT secret — use a long random string (min 32 chars) in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_strong_random_secret

# Backend server port
PORT=8000

# Frontend origin (for CORS)
CLIENT_URL=http://localhost:5173

# Node environment: development | production
NODE_ENV=development
