    {
      "name": "Support Ticket Helpdesk",
      "item": [
        {
          "name": "Open Help Ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Lost Item in Vehicle\",\n  \"message\": \"I left my black leather wallet in the Toyota Prius plate CAB-TX-9876 this afternoon.\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/support",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "support"]
            }
          }
        },
        {
          "name": "Reply to Ticket (Admin / User)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"We have contacted driver Dave. He has located the wallet and will drop it at the nearest hub.\",\n  \"status\": \"Resolved\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/support/{{ticket_id}}/reply",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "support", "{{ticket_id}}", "reply"]
