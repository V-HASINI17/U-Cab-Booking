    {
      "name": "Cab Fleet Operations",
      "item": [
        {
          "name": "Get All Available Cabs (Nearby Search)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8000/api/cars?status=Available&city=New York",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "cars"],
              "query": [
                { "key": "status", "value": "Available" },
                { "key": "city", "value": "New York" }
              ]
            }
          }
        },
        {
          "name": "Register New Cab (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Chevrolet Suburban XL", "type": "text" },
                { "key": "type", "value": "SUV", "type": "text" },
                { "key": "number", "value": "NY-SUV-882", "type": "text" },
                { "key": "seats", "value": "6", "type": "text" },
                { "key": "pricePerKm", "value": "22", "type": "text" },
                { "key": "city", "value": "New York", "type": "text" },
                { "key": "image", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "http://localhost:8000/api/cars",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "cars"]
            }
          }
        }
      ]
    },
    {
