          "name": "Verify Driver Account",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Verified\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/admin/drivers/{{driver_id}}/verify",
              "protocol": "http",
              "host": ["localhost"],
