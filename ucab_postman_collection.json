          }
        },
        {
          "name": "Get Dashboard Telemetry Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8000/api/admin/dashboard-stats",
