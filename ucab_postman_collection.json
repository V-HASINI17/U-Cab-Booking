{
  "info": {
    "_postman_id": "8b5f3a09-9fcf-49b8-b80c-03ebf81a7d65",
    "name": "UCAB API Collection",
    "description": "API collection for UCAB Cab Booking System, covering authentication, driver registration, cab fleet management, bookings, fare estimation, simulated checkouts, and support tickets.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User & Driver Authentication",
      "item": [
        {
          "name": "User Registration (Passenger)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Passenger\",\n  \"email\": \"john@passenger.com\",\n  \"password\": \"password123\",\n  \"mobile\": \"+15551234567\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/users/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "users", "register"]
            }
          }
        },
        {
          "name": "Driver Registration (Partner)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dave Driver\",\n  \"email\": \"dave@driver.com\",\n  \"password\": \"password123\",\n  \"mobile\": \"+15559876543\",\n  \"role\": \"driver\",\n  \"driverDetails\": {\n    \"licenseNumber\": \"DL-CA992381\",\n    \"vehicleModel\": \"Toyota Prius Hybrid\",\n    \"vehicleNumber\": \"CAB-TX-9876\",\n    \"vehicleType\": \"Sedan\",\n    \"experienceYears\": 5\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/users/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "users", "register"]
            }
          }
        },
        {
          "name": "User / Driver Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@passenger.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/users/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "users", "login"]
            }
          }
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8000/api/users/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "users", "me"]
            }
          }
        },
        {
          "name": "Update Driver Location Telemetry",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driver_jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"city\": \"Boston\",\n  \"lat\": 42.3601,\n  \"lng\": -71.0589\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/users/telemetry",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "users", "telemetry"]
            }
          }
        }
      ]
    },
